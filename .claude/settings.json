{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(make:*)",
      "Bash(nerdctl compose:*)",
      "Bash(alembic:*)",
      "Bash(pytest:*)"
    ],
    "deny": [
      "Read(./.env)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
