# Copy to .env and fill in. Never commit .env.

# PostgreSQL connection string (used by backend + Alembic).
DATABASE_URL=postgresql+psycopg://meetmind:meetmind@localhost:5432/meetmind

# OpenAI-compatible gateway credentials.
LLM_API_KEY=sk-replace-me

# Base URL for the OpenAI-compatible endpoint (no trailing /v1 needed if the SDK adds it).
BASE_URL=https://your-gateway.example.com/v1

# Model served by the gateway.
MODEL_NAME=claude-opus-4-6
